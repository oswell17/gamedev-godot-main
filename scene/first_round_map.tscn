[node name="Note" parent="." unique_id=358346354 instance=ExtResource("12_wioj2")]
position = Vector2(161.99998, 166.4)
note_pages = Array[String](["Hey. If you’re reading this, the sedatives finally wore off. I waited as long as I could,", "but the hoard broke through the north wing and the smell started drawing them to this floor.", "I left the key for 4th floor main door to room 428. Probably the staff close the door on this floor", "to avoid the horde to reach this room.", "I left you a flashlight and knife on room 408, 'Cause I know you might need it.", "Move to 3rd floor, and I have something for you that might help you escape this hospital.", "Don't make me regret leaving you behind. Move fast, stay quiet."])

[node name="Note2" parent="." unique_id=806188792 instance=ExtResource("12_wioj2")]
position = Vector2(2194.9998, 1940.1997)
scale = Vector2(0.9999998, 0.9999998)
note_pages = Array[String](["If you are reading this, then you finally found the key.", "We are going to Doctor's Office Room 1, we already camped there and that room is already safe.", "So you dont need to worry about being bitten.", "I will leave some gear to you in that room, so it would be best to grab it.", "Be safe out there!"])

